{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "rootDir": "..",
    "outDir": "../dist-tateside-api"
  },
  "include": [
    "src/**/*.ts",
    "../src/types.ts",
    "../src/quoteImportTypes.ts",
    "../src/deviceTypeCategories.ts"
  ]
}
